# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT configuration
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# Database
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./hush.db
# PostgreSQL (production) — swap in when deploying
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hush

# CORS
ALLOWED_ORIGINS=http://localhost:3000
